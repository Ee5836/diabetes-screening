/* ============================================================
   糖尿病风险筛查工具 — 全局样式 (Design Tokens)
   适配微信小程序 WXSS，750rpx 设计稿
   ============================================================ */

/* ---- Design Tokens ---- */
page {
  --color-bg:            #F7F3EE;
  --color-surface:       #FFFFFF;
  --color-primary:       #6B9BD2;
  --color-primary-dark:  #4F85BF;
  --color-primary-light: #E9F1F9;
  --color-primary-ghost: #F4F8FC;
  --color-success:       #7EB89C;
  --color-warning:       #E2B85A;
  --color-alert:         #E2936B;
  --color-danger:        #D4756B;
  --color-text:          #3E3A38;
  --color-text-secondary:#8E8984;
  --color-text-muted:    #B5B0AA;
  --color-border:        #E8E3DB;
  --color-border-light:  #F0ECE6;
  --color-input-bg:      #F5F3EF;
  --color-input-border:  #B5ADA2;

  --radius-sm:           8rpx;
  --radius-md:           12rpx;
  --radius-lg:           16rpx;
  --radius-xl:           24rpx;

  --font-stack:          -apple-system, BlinkMacSystemFont, "PingFang SC",
                         "Microsoft YaHei", "Helvetica Neue", sans-serif;

  --input-h:             80rpx;
  --gap-row:             18rpx;
  --gap-section:         22rpx;

  background: #F7F3EE;
  font-family: var(--font-stack);
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
}

/* ============================================================
   共享表单组件样式 (form-basic / form-advanced)
   ============================================================ */

/* ---- Section Heading ---- */
.section-heading {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--gap-section);
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--color-primary-light);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
}

.section-sub {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-muted);
  margin-left: auto;
  flex-shrink: 0;
}

/* ---- Form Layout ---- */
.form-row {
  display: flex;
  gap: var(--gap-row);
  margin-bottom: var(--gap-section);
}

.form-group {
  flex: 1;
  min-width: 0;
}

/* ---- Label (字段名 — 深色粗体) ---- */
.form-label {
  display: -webkit-box;
  height: 64rpx;
  line-height: 32rpx;
  font-weight: 700;
  font-size: 26rpx;
  margin-bottom: 8rpx;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.form-label .unit {
  font-weight: 400;
  color: var(--color-text-muted);
  font-size: 22rpx;
}

/* ---- Input (填选框 — 灰底+可见边框) ---- */
.form-input {
  width: 100%;
  height: var(--input-h);
  padding: 0 24rpx;
  border: 2rpx solid var(--color-input-border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
  background: var(--color-input-bg);
  box-sizing: border-box;
}

/* ---- Placeholder 文本 (浅淡，区分于输入内容) ---- */
.input-placeholder {
  font-size: 26rpx;
  color: #C5C0B8;
}

/* ---- Picker (选择框 — 灰底+可见边框+下拉箭头) ---- */
.picker-display {
  display: flex;
  align-items: center;
  width: 100%;
  height: var(--input-h);
  padding: 0 20rpx 0 24rpx;
  border: 2rpx solid var(--color-input-border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
  background: var(--color-input-bg);
  box-sizing: border-box;
}

.picker-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  flex-shrink: 0;
  margin-left: 8rpx;
  font-size: 18rpx;
  color: #B5B0AA;
}

/* ---- Button ---- */
.btn-primary {
  display: block;
  width: 100%;
  max-width: 500rpx;
  margin: 8rpx auto 0;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  background: linear-gradient(135deg, #6B9BD2 0%, #5A8BC2 100%);
  border: none;
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 16rpx rgba(107,155,210,0.25);
}

.btn-primary:active {
  opacity: 0.85;
}
