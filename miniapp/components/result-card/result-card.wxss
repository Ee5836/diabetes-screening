/* ============================================================
   结果卡片样式
   ============================================================ */

.result-card {
  margin-top: 40rpx;
}

.result-title {
  text-align: center;
  margin-bottom: 28rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}

.result-body {
  text-align: center;
  padding: 44rpx 36rpx;
  border-radius: var(--radius-lg);
  border: 2rpx solid;
}

/* ---- Risk Level ---- */
.risk-level {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

/* ---- Probability ---- */
.prob-number {
  font-size: 64rpx;
  font-weight: 800;
  margin: 20rpx 0 4rpx;
}

.prob-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 20rpx;
}

/* ---- Progress Bar ---- */
.bar-bg {
  background: rgba(62,58,56,0.08);
  border-radius: 100rpx;
  height: 14rpx;
  margin: 24rpx 0;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 100rpx;
  transition: width 0.8s ease;
}

/* ---- Advice ---- */
.advice {
  margin: 20rpx 0;
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--color-text);
}

/* ---- Separator ---- */
.meta-line {
  border-top: 1rpx solid rgba(62,58,56,0.08);
  margin: 28rpx 0 20rpx;
}

/* ---- Meta Info ---- */
.meta-info {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 2rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.8;
}

/* ---- Disclaimer ---- */
.disclaimer {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.6;
}
