/* ============================================================
   主页面样式
   ============================================================ */

.page {
  padding: 32rpx 20rpx 48rpx;
  max-width: 960rpx;
  margin: 0 auto;
}

/* ---- Header ---- */
.header {
  text-align: center;
  padding: 24rpx 0 0;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 52rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

.header-title .accent {
  color: var(--color-primary-dark);
}

.header-desc {
  color: var(--color-text-muted);
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* ---- Main Card ---- */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  box-shadow: 0 8rpx 32rpx rgba(62,58,56,0.08);
}

/* ---- Tab Navigation ---- */
.tab-nav {
  display: flex;
  background: var(--color-primary-ghost);
  border-bottom: 1rpx solid var(--color-border);
  padding: 6rpx;
  gap: 4rpx;
}

.tab-btn {
  flex: 1;
  padding: 26rpx 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all 0.2s;
  text-align: center;
}

.tab-btn-active {
  color: var(--color-primary-dark);
  background: var(--color-surface);
  box-shadow: 0 1rpx 3rpx rgba(62,58,56,0.06);
}

/* ---- Tab Body ---- */
.tab-body {
  padding: 32rpx 36rpx;
}

/* ---- Loading Overlay ---- */
.loading-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(251,248,244,0.88);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

/* ---- Footer ---- */
.footer {
  text-align: center;
  color: var(--color-text-muted);
  font-size: 22rpx;
  padding: 28rpx 0 4rpx;
}

/* ============================================================
   免责声明弹窗
   ============================================================ */

.disclaimer-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
  padding: 60rpx 36rpx;
  box-sizing: border-box;
}

.disclaimer-modal {
  width: 100%;
  max-width: 640rpx;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: var(--radius-xl);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.disclaimer-modal-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  padding: 32rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.disclaimer-modal-body {
  flex: 1;
  min-height: 0;
  padding: 0 32rpx;
  overflow-y: auto;
}

.disclaimer-modal-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.9;
  margin-bottom: 14rpx;
  text-align: justify;
  word-break: break-all;
}

.disclaimer-strong {
  color: var(--color-danger);
  font-weight: 600;
}

/* ---- Footer ---- */
.disclaimer-modal-footer {
  flex-shrink: 0;
  padding: 24rpx 32rpx 36rpx;
  border-top: 1rpx solid var(--color-border-light);
  margin-top: 8rpx;
}

.disclaimer-check {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 24rpx;
  padding: 8rpx 0;
}

.check-box {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.check-box-on {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.check-mark {
  font-size: 26rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.check-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.countdown-hint {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 12rpx;
}

.disclaimer-btn {
  width: 100%;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #B5B0AA;
  background: #F0ECE6;
  border: none;
  border-radius: var(--radius-md);
  transition: all 0.25s;
}

.disclaimer-btn-active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #6B9BD2 0%, #5A8BC2 100%);
  box-shadow: 0 4rpx 16rpx rgba(107, 155, 210, 0.25);
}
